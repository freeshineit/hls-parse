{
  "name": "@skax/hls-parse",
  "version": "1.0.0",
  "description": "A robust M3U8/HLS playlist parser supporting RFC 8216, Master playlists, Media playlists, and LL-HLS (Low-Latency HLS)",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "cross-env NODE_ENV=development rollup -c -w",
    "build": "cross-env NODE_ENV=production rollup -c",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "example": "ts-node examples/basic.ts",
    "lint": "eslint --fix \"./src/**/*.{ts,tsx,js,jsx,mjs,vue,cjs}\"",
    "lint:check": "eslint \"./src/**/*.{ts,tsx,js,jsx,mjs,vue,cjs}\"",
    "fmt": "prettier --write \"./**/*.{ts,tsx,js,jsx,mjs,json,md,yml,yaml,vue,cjs,css,scss,sass}\"",
    "fmt:check": "prettier --check \"./**/*.{ts,tsx,js,jsx,mjs,json,md,yml,yaml,vue,cjs,css,scss,sass}\"",
    "prepare": "husky"
  },
  "keywords": [
    "hls",
    "m3u8",
    "playlist",
    "parser",
    "http-live-streaming",
    "ll-hls",
    "low-latency"
  ],
  "author": "ShineShao <xiaoshaoqq@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.23.3",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@skax/rollup-config": "^1.0.8",
    "@types/jest": "^29.5.12",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-xx": "^2.2.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "rollup": "^4.60.4",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-serve": "^3.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
